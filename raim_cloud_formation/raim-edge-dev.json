        "ManagedLoginVersion": 2,
        "UserPoolId": {
          "Ref": "CognitoUserPool"
        }
      }
    },
    "CognitoGoogleIdentityProvider": {
      "Type": "AWS::Cognito::UserPoolIdentityProvider",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "UserPoolId": {
