{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "RAiM edge resources template v10. This version syncs the imported Google IdP and enables Google on the Cognito user pool client.",
  "Parameters": {
    "ProjectName": {
      "Type": "String",
      "Default": "RAiM"
    },
    "TeamName": {
      "Type": "String",
      "Default": "Sign"
    },
    "Environment": {
      "Type": "String",
      "Default": "dev",
      "AllowedValues": [
        "dev",
        "stg",
        "prod"
      ]
    },
    "StageName": {
      "Type": "String",
      "Default": "dev"
    },
    "UserPoolArn": {
      "Type": "String",
      "Default": "arn:aws:cognito-idp:ap-northeast-1:990442281360:userpool/ap-northeast-1_OMFV9fgsG",
      "Description": "Existing Cognito User Pool ARN used by the API Gateway authorizer."
    },
    "GoogleOAuthClientId": {
      "Type": "String",
      "Description": "Existing Google OAuth client ID used by the Cognito Google identity provider."
    },
    "GoogleOAuthSecretName": {
      "Type": "String",
      "Default": "raim/dev/google-oauth",
      "Description": "Secrets Manager secret name containing the Google OAuth client secret under key 'client_secret'."
    }
  },
  "Resources": {
    "RaimRestApi": {
      "Type": "AWS::ApiGateway::RestApi",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "Name": "raim-api-dev",
        "Description": "??????????????",
        "EndpointConfiguration": {
          "Types": [
            "REGIONAL"
          ],
          "IpAddressType": "ipv4"
        },
        "Tags": [
          {
            "Key": "Team",
            "Value": {
              "Ref": "TeamName"
            }
          }
        ]
      }
    },
    "ChatResource": {
      "Type": "AWS::ApiGateway::Resource",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "ParentId": {
          "Fn::GetAtt": [
            "RaimRestApi",
            "RootResourceId"
          ]
        },
        "PathPart": "chat"
      }
    },
    "CognitoAuthorizer": {
      "Type": "AWS::ApiGateway::Authorizer",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "Name": "raim-cognito-authorizer",
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "Type": "COGNITO_USER_POOLS",
        "IdentitySource": "method.request.header.Authorization",
        "ProviderARNs": [
          {
            "Ref": "UserPoolArn"
          }
        ]
      }
    },
    "ChatPostMethod": {
      "Type": "AWS::ApiGateway::Method",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "ResourceId": {
          "Ref": "ChatResource"
        },
        "HttpMethod": "POST",
        "AuthorizationType": "COGNITO_USER_POOLS",
        "AuthorizerId": {
          "Ref": "CognitoAuthorizer"
        },
        "AuthorizationScopes": [
          "openid"
        ],
        "ApiKeyRequired": true,
        "OperationName": "PostChat",
        "Integration": {
          "Type": "MOCK",
          "RequestTemplates": {
            "application/json": "{\"statusCode\": 200}"
          },
          "IntegrationResponses": [
            {
              "StatusCode": "200"
            }
          ]
        },
        "MethodResponses": [
          {
            "StatusCode": "200",
            "ResponseModels": {
              "application/json": "Empty"
            }
          }
        ]
      }
    },
    "EdgeOriginApiKey": {
      "Type": "AWS::ApiGateway::ApiKey",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "Name": "raim-key-dev",
        "Description": "API key for CloudFront origin custom header to RAiM dev API",
        "Enabled": true,
        "Tags": [
          {
            "Key": "Project",
            "Value": {
              "Ref": "ProjectName"
            }
          },
          {
            "Key": "Team",
            "Value": {
              "Ref": "TeamName"
            }
          },
          {
            "Key": "Environment",
            "Value": {
              "Ref": "Environment"
            }
          },
          {
            "Key": "ManagedBy",
            "Value": "manual"
          },
          {
            "Key": "Purpose",
            "Value": "edge-origin-auth"
          }
        ]
      }
    },
    "UsagePlan": {
      "Type": "AWS::ApiGateway::UsagePlan",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "UsagePlanName": "raim-usage-plan-dev",
        "Description": "Usage plan for RAiM dev API through CloudFront",
        "ApiStages": [
          {
            "ApiId": {
              "Ref": "RaimRestApi"
            },
            "Stage": {
              "Ref": "StageName"
            }
          }
        ],
        "Throttle": {
          "RateLimit": 10,
          "BurstLimit": 20
        },
        "Quota": {
          "Limit": 10000,
          "Period": "MONTH"
        }
      }
    },
    "UsagePlanKey": {
      "Type": "AWS::ApiGateway::UsagePlanKey",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "KeyId": {
          "Ref": "EdgeOriginApiKey"
        },
        "KeyType": "API_KEY",
        "UsagePlanId": {
          "Ref": "UsagePlan"
        }
      }
    },
    "CurrentDeployment": {
      "Type": "AWS::ApiGateway::Deployment",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "RestApiId": {
          "Ref": "RaimRestApi"
        }
      }
    },
    "DevStage": {
      "Type": "AWS::ApiGateway::Stage",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "StageName": {
          "Ref": "StageName"
        },
        "DeploymentId": {
          "Ref": "CurrentDeployment"
        }
      }
    },
    "CloudFrontDistribution": {
      "UpdateReplacePolicy": "Retain",
      "Type": "AWS::CloudFront::Distribution",
      "DeletionPolicy": "Retain",
      "Properties": {
        "DistributionConfig": {
          "Logging": {
            "IncludeCookies": false,
            "Bucket": "",
            "Prefix": ""
          },
          "Comment": "for RAiM",
          "DefaultRootObject": "",
          "Origins": [
            {
              "ConnectionTimeout": 10,
              "OriginAccessControlId": "",
              "ConnectionAttempts": 3,
              "OriginCustomHeaders": [
                {
                  "HeaderName": "x-api-key",
                  "HeaderValue": "{{resolve:secretsmanager:raim/dev/cloudfront-origin:SecretString:CloudFrontOriginApiKey}}"
                }
              ],
              "DomainName": "nqa57ts4di.execute-api.ap-northeast-1.amazonaws.com",
              "OriginShield": {
                "Enabled": false
              },
              "OriginPath": "/dev",
              "Id": "nqa57ts4di.execute-api.ap-northeast-1.amazonaws.com-mpwafk0az4k",
              "CustomOriginConfig": {
                "IpAddressType": "ipv4",
                "OriginReadTimeout": 30,
                "HTTPSPort": 443,
                "OriginKeepaliveTimeout": 5,
                "OriginSSLProtocols": [
                  "TLSv1.2"
                ],
                "HTTPPort": 80,
                "OriginProtocolPolicy": "https-only"
              }
            }
          ],
          "ViewerCertificate": {
            "CloudFrontDefaultCertificate": true
          },
          "PriceClass": "PriceClass_All",
          "DefaultCacheBehavior": {
            "Compress": true,
            "FunctionAssociations": [],
            "LambdaFunctionAssociations": [],
            "TargetOriginId": "nqa57ts4di.execute-api.ap-northeast-1.amazonaws.com-mpwafk0az4k",
            "ViewerProtocolPolicy": "redirect-to-https",
            "GrpcConfig": {
              "Enabled": false
            },
            "TrustedSigners": [],
            "FieldLevelEncryptionId": "",
            "TrustedKeyGroups": [],
            "AllowedMethods": [
              "HEAD",
              "DELETE",
              "POST",
              "GET",
              "OPTIONS",
              "PUT",
              "PATCH"
            ],
            "CachedMethods": [
              "HEAD",
              "GET"
            ],
            "SmoothStreaming": false,
            "OriginRequestPolicyId": "b689b0a8-53d0-40ab-baf2-68738e2966ac",
            "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad"
          },
          "Staging": false,
          "CustomErrorResponses": [],
          "ContinuousDeploymentPolicyId": "",
          "OriginGroups": {
            "Quantity": 0,
            "Items": []
          },
          "Enabled": true,
          "Aliases": [],
          "IPV6Enabled": true,
          "WebACLId": "arn:aws:wafv2:us-east-1:990442281360:global/webacl/CreatedByCloudFront-0551704e/4ae51ded-2520-428e-bc93-ab4ef2f082ad",
          "HttpVersion": "http2",
          "Restrictions": {
            "GeoRestriction": {
              "Locations": [],
              "RestrictionType": "none"
            }
          },
          "CacheBehaviors": []
        },
        "Tags": [
          {
            "Value": "Sign",
            "Key": "Team"
          },
          {
            "Value": "raim-cloudfront-dev",
            "Key": "Name"
          }
        ]
      }
    },
    "CognitoUserPool": {
      "UpdateReplacePolicy": "Retain",
      "Type": "AWS::Cognito::UserPool",
      "DeletionPolicy": "Retain",
      "Properties": {
        "UserPoolTags": {
          "Team": "Sign"
        },
        "Policies": {
          "PasswordPolicy": {
            "TemporaryPasswordValidityDays": 7,
            "RequireUppercase": true,
            "RequireNumbers": true,
            "RequireLowercase": true,
            "MinimumLength": 8,
            "RequireSymbols": true
          },
          "SignInPolicy": {
            "AllowedFirstAuthFactors": [
              "PASSWORD"
            ]
          }
        },
        "VerificationMessageTemplate": {
          "DefaultEmailOption": "CONFIRM_WITH_CODE"
        },
        "MfaConfiguration": "OFF",
        "Schema": [
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
            "AttributeDataType": "String",
            "StringAttributeConstraints": {
              "MaxLength": "2048",
              "MinLength": "0"
            },
            "Required": false,
            "Name": "profile"
          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
            "AttributeDataType": "String",
            "StringAttributeConstraints": {
              "MaxLength": "2048",
              "MinLength": "0"
            },
            "Required": false,
            "Name": "address"
          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
