          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": false,
            "AttributeDataType": "String",
            "StringAttributeConstraints": {
              "MaxLength": "2048",
              "MinLength": "1"
            },
            "Required": true,
            "Name": "sub"
          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
            "AttributeDataType": "String",
            "StringAttributeConstraints": {
              "MaxLength": "2048",
              "MinLength": "0"
            },
            "Required": false,
