            },
            "Required": false,
            "Name": "gender"
          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
            "AttributeDataType": "String",
            "StringAttributeConstraints": {
              "MaxLength": "2048",
              "MinLength": "0"
            },
            "Required": false,
            "Name": "preferred_username"
          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
            "AttributeDataType": "Number",
            "Required": false,
            "NumberAttributeConstraints": {
              "MinValue": "0"
            },
            "Name": "updated_at"
          },
          {
            "DeveloperOnlyAttribute": false,
            "Mutable": true,
            "AttributeDataType": "String",
            "StringAttributeConstraints": {
              "MaxLength": "2048",
