{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "RAiM edge resources import template. This template is intended for CloudFormation resource import of the existing manually-created Cognito/API Gateway/API Key/Usage Plan edge configuration. All imported resources have DeletionPolicy: Retain.",
  "Parameters": {
    "ProjectName": {
      "Type": "String",
      "Default": "RAiM"
    },
    "TeamName": {
      "Type": "String",
      "Default": "Sign"
    },
    "Environment": {
      "Type": "String",
      "Default": "dev"
    },
    "UserPoolArn": {
      "Type": "String",
      "Default": "arn:aws:cognito-idp:ap-northeast-1:990442281360:userpool/ap-northeast-1_OMFV9fgsG",
      "Description": "Existing Cognito User Pool ARN used by API Gateway Authorizer."
    },
    "RestApiId": {
      "Type": "String",
      "Default": "nqa57ts4di",
      "Description": "Existing API Gateway REST API ID."
    },
    "ChatResourceId": {
      "Type": "String",
      "Default": "brx70l",
      "Description": "Existing API Gateway /chat resource ID."
    },
    "AuthorizerId": {
      "Type": "String",
      "Default": "1ksbek",
      "Description": "Existing API Gateway Cognito Authorizer ID."
    },
    "ApiKeyId": {
      "Type": "String",
      "Default": "imb4h2ilu3",
      "Description": "Existing API Gateway API Key ID."
    },
    "UsagePlanId": {
      "Type": "String",
      "Default": "7g2e39",
      "Description": "Existing API Gateway Usage Plan ID."
    },
    "UsagePlanKeyId": {
      "Type": "String",
      "Default": "7g2e39",
      "Description": "Existing UsagePlanKey ID, if importing the API key to usage plan association."
    }
  },
  "Conditions": {
    "ImportUsagePlanKey": {
      "Fn::Not": [
        {
          "Fn::Equals": [
            {
              "Ref": "UsagePlanKeyId"
            },
            ""
          ]
        }
      ]
    }
  },
  "Resources": {
    "RaimRestApi": {
      "Type": "AWS::ApiGateway::RestApi",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "Name": "raim-api-dev",
        "Description": "タイムアウトの延長を申請予定",
        "EndpointConfiguration": {
          "Types": [
            "REGIONAL"
          ],
          "IpAddressType": "ipv4"
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": {
              "Ref": "ProjectName"
            }
          },
          {
            "Key": "Team",
            "Value": {
              "Ref": "TeamName"
            }
          },
          {
            "Key": "Environment",
            "Value": {
              "Ref": "Environment"
            }
          },
          {
            "Key": "ManagedBy",
            "Value": "manual"
          },
          {
            "Key": "Purpose",
            "Value": "api"
          }
        ]
      }
    },
    "ChatResource": {
      "Type": "AWS::ApiGateway::Resource",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "ParentId": {
          "Fn::GetAtt": [
            "RaimRestApi",
            "RootResourceId"
          ]
        },
        "PathPart": "chat"
      }
    },
    "CognitoAuthorizer": {
      "Type": "AWS::ApiGateway::Authorizer",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "Name": "raim-cognito-authorizer",
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "Type": "COGNITO_USER_POOLS",
        "IdentitySource": "method.request.header.Authorization",
        "ProviderARNs": [
          {
            "Ref": "UserPoolArn"
          }
        ]
      }
    },
    "ChatPostMethod": {
      "Type": "AWS::ApiGateway::Method",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "RestApiId": {
          "Ref": "RaimRestApi"
        },
        "ResourceId": {
          "Ref": "ChatResource"
        },
        "HttpMethod": "POST",
        "AuthorizationType": "COGNITO_USER_POOLS",
        "AuthorizerId": {
          "Ref": "CognitoAuthorizer"
        },
        "AuthorizationScopes": [
          "openid"
        ],
        "ApiKeyRequired": true,
        "OperationName": "PostChat",
        "Integration": {
          "Type": "MOCK",
          "RequestTemplates": {
            "application/json": "{\"statusCode\": 200}"
          },
          "IntegrationResponses": [
            {
              "StatusCode": 200,
              "ResponseTemplates": {
                "application/json": ""
              }
            }
          ]
        },
        "MethodResponses": [
          {
            "StatusCode": 200,
            "ResponseModels": {
              "application/json": "Empty"
            }
          }
        ]
      }
    },
    "EdgeOriginApiKey": {
      "Type": "AWS::ApiGateway::ApiKey",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "Name": "raim-key-dev",
        "Description": "API key for CloudFront origin custom header to RAiM dev API",
        "Enabled": true,
        "Tags": [
          {
            "Key": "Project",
            "Value": {
              "Ref": "ProjectName"
            }
          },
          {
            "Key": "Team",
            "Value": {
              "Ref": "TeamName"
            }
          },
          {
            "Key": "Environment",
            "Value": {
              "Ref": "Environment"
            }
          },
          {
            "Key": "ManagedBy",
            "Value": "manual"
          },
          {
            "Key": "Purpose",
            "Value": "edge-origin-auth"
          }
        ]
      }
    },
    "UsagePlan": {
      "Type": "AWS::ApiGateway::UsagePlan",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "UsagePlanName": "raim-usage-plan-dev",
        "Description": "Usage plan for RAiM dev API through CloudFront",
        "ApiStages": [
          {
            "ApiId": {
              "Ref": "RaimRestApi"
            },
            "Stage": "dev"
          }
        ],
        "Throttle": {
          "RateLimit": 10,
          "BurstLimit": 20
        },
        "Quota": {
          "Limit": 10000,
          "Period": "MONTH"
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": {
              "Ref": "ProjectName"
            }
          },
          {
            "Key": "Team",
            "Value": {
              "Ref": "TeamName"
            }
          },
          {
            "Key": "Environment",
            "Value": {
              "Ref": "Environment"
            }
          },
          {
            "Key": "ManagedBy",
            "Value": "manual"
          },
          {
            "Key": "Purpose",
            "Value": "api-usage-plan"
          }
        ]
      }
    },
    "UsagePlanKey": {
      "Type": "AWS::ApiGateway::UsagePlanKey",
      "Condition": "ImportUsagePlanKey",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "KeyId": {
          "Ref": "EdgeOriginApiKey"
        },
        "KeyType": "API_KEY",
        "UsagePlanId": {
          "Ref": "UsagePlan"
        }
      }
    }
  },
  "Outputs": {
    "RestApiId": {
      "Value": {
        "Ref": "RaimRestApi"
      }
    },
    "ApiGatewayInvokeUrl": {
      "Value": {
        "Fn::Sub": "https://${RaimRestApi}.execute-api.${AWS::Region}.amazonaws.com/dev/chat"
      }
    },
    "ChatResourceId": {
      "Value": {
        "Ref": "ChatResource"
      }
    },
    "AuthorizerId": {
      "Value": {
        "Ref": "CognitoAuthorizer"
      }
    },
    "ApiKeyId": {
      "Value": {
        "Ref": "EdgeOriginApiKey"
      }
    },
    "UsagePlanId": {
      "Value": {
        "Ref": "UsagePlan"
      }
    }
  }
}